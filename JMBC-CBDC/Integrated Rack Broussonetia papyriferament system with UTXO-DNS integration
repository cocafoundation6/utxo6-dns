// packages/core/compliance-router/RegionRouter.ts
// Author: J. Tian (uw2icg-core)

export interface UserTier {
  userId: string;
  region: 'MAINLAND' | 'OVERSEAS_TOURIST' | 'HK_LICENSED' | 'INBOUND_TOURIST';
  kycLevel: 1 | 2 | 3;
  yearlyOutboundLimit: number;
  yearlyUsed: number;
}

export interface PaymentRequest {
  userId: string;
  amount: number;
  currency: string;
  targetCurrency?: string;
  merchantId?: string;
  qrPayload?: string;
  scenario?: 'DOMESTIC' | 'OVERSEAS_TOURISM' | 'INBOUND_PAYMENT' | 'RWA_CONVERSION';
  sourceAccount?: string;
}

export interface RouteResult {
  allowed: boolean;
  action: 'PAYMENT_VIA_ECNY' | 'CNH_SMART_SETTLEMENT' | 'RWA_CONVERSION' | 'INBOUND_HARDWARE_WALLET' | 'REJECTED';
  note: string;
  codePath: string;
  quote?: RouteQuote;
  reason?: string;
}

export interface RouteQuote {
  provider: string;
  exchangeRate: number;
  fee: number;
  settlementTime: string;
  savingsVsAirport?: number;
}

export class RegionComplianceRouter {
  private userRegistry: Map<string, UserTier> = new Map();
  private cnhRouter: CNHSmartRouter;
  private vleiVerifier: VLEIVerifier;

  constructor() {
    this.cnhRouter = new CNHSmartRouter();
    this.vleiVerifier = new VLEIVerifier();
  }

  async getUserTier(userId: string): Promise<UserTier> {
    const user = this.userRegistry.get(userId);
    if (!user) throw new Error(`User ${userId} not found`);
    return user;
  }

  async routePayment(request: PaymentRequest): Promise<RouteResult> {
    const tier = await this.getUserTier(request.userId);

    // ZONE 1: MAINLAND – e-CNY direct payment only
    if (tier.region === 'MAINLAND') {
      return {
        allowed: true,
        action: 'PAYMENT_VIA_ECNY',
        note: 'Strictly e-CNY direct payment. Crypto conversion prohibited under 42号通知.',
        codePath: 'packages/domestic-receipt'
      };
    }

    // ZONE 2: OVERSEAS TOURISM – CNH smart routing (no crypto)
    if (tier.region === 'OVERSEAS_TOURIST' && request.scenario === 'OVERSEAS_TOURISM') {
      const limitRemaining = tier.yearlyOutboundLimit - tier.yearlyUsed;
      if (request.amount > limitRemaining) {
        return {
          allowed: false,
          action: 'REJECTED',
          note: 'Yearly outbound limit exceeded. Please use other payment methods.',
          codePath: '',
          reason: `Limit remaining: ${limitRemaining}, Requested: ${request.amount}`
        };
      }
      const quote = await this.cnhRouter.getOptimalRoute(request.amount, request.targetCurrency || 'USD');
      return {
        allowed: true,
        action: 'CNH_SMART_SETTLEMENT',
        note: 'Settled via offshore CNH from HK licensed banks. No stablecoin involved.',
        codePath: 'packages/cnh-routing',
        quote
      };
    }

    // ZONE 3: HONG KONG LICENSED – RWA conversion (isolated)
    if (tier.region === 'HK_LICENSED' && tier.kycLevel >= 3) {
      const vleiStatus = await this.vleiVerifier.verify(request.merchantId || '');
      if (!vleiStatus.valid) {
        return {
          allowed: false,
          action: 'REJECTED',
          note: 'vLEI verification failed. Entity not active or sanctioned.',
          codePath: '',
          reason: `vLEI status: ${vleiStatus.status}`
        };
      }
      return {
        allowed: true,
        action: 'RWA_CONVERSION',
        note: 'HK licensed entities only. Data physically isolated from mainland nodes.',
        codePath: 'packages/hk-coca-dex'
      };
    }

    // ZONE 4: INBOUND FOREIGN TOURISTS – hardware wallet or bound card only
    if (tier.region === 'INBOUND_TOURIST') {
      if (request.sourceAccount && this.isCryptoAddress(request.sourceAccount)) {
        return {
          allowed: false,
          action: 'REJECTED',
          note: 'Crypto assets not accepted for inbound payments under 42号通知.',
          codePath: '',
          reason: 'Source account appears to be a crypto address (0x... or bc1...).'
        };
      }
      return {
        allowed: true,
        action: 'INBOUND_HARDWARE_WALLET',
        note: 'Use official e-CNY hardware wallet or bound international card (Visa/Mastercard).',
        codePath: 'packages/inbound-adapter'
      };
    }

    return {
      allowed: false,
      action: 'REJECTED',
      note: 'Unsupported region or compliance level.',
      codePath: '',
      reason: `Region: ${tier.region}, KYC: ${tier.kycLevel}`
    };
  }

  private isCryptoAddress(address: string): boolean {
    if (/^0x[a-fA-F0-9]{40}$/.test(address)) return true;
    if (/^(bc1|[13])[a-zA-HJ-NP-Z0-9]{25,90}$/.test(address)) return true;
    if (/^[1-9A-HJ-NP-Za-km-z]{32,44}$/.test(address)) return true;
    return false;
  }

  async registerUser(user: UserTier): Promise<void> {
    this.userRegistry.set(user.userId, user);
  }
}
