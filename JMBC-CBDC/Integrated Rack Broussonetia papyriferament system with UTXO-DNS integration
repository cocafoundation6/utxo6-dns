      legalAddress: '123 Main St, Hong Kong',
      jurisdiction: 'HK',
      lei: `LEI${vleiDID.slice(-18)}`
    };
  }

  async verifyCredential(credential: VLEICredential): Promise<boolean> {
    try {
      const now = new Date();
      if (credential.validFrom > now || credential.validUntil < now) return false;
      const status = await this.verify(credential.subject);
      if (!status.valid) return false;
      for (const auth of credential.authorization) {
        if (!auth.role || !auth.authority) return false;
      }
      return true;
    } catch {
      return false;
    }
  }

  async batchVerify(vleiDIDs: string[]): Promise<Map<string, VLEIStatus>> {
    const results = new Map<string, VLEIStatus>();
    for (const did of vleiDIDs) {
      try {
        const status = await this.verify(did);
        results.set(did, status);
      } catch {
        results.set(did, {
          valid: false,
          status: 'REVOKED',
          legalName: '',
          legalAddress: '',
          jurisdiction: '',
          lei: '',
          lastUpdated: new Date()
        });
      }
    }
    return results;
  }
}
