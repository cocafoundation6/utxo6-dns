  authToken: string;        // SUA/2FA token
  qrPayload: string;        // ISO 20022 format payment instruction
  amount: number;
  currency: 'EUR' | 'CNY';
  merchantId: string;
}

export interface PaymentResult {
  transactionId: string;
  amount: number;
  currency: string;
  merchantId: string;
  userId: string;
  timestamp: Date;
  verificationCode: string;
  receiptHash: string;
}

export class EUDIWalletAdapter {
  private ecnyRouter: RegionComplianceRouter;
  private iso20022Builder: ISO20022PaymentBuilder;

  constructor() {
    this.ecnyRouter = new RegionComplianceRouter();
    this.iso20022Builder = new ISO20022PaymentBuilder();
  }

  async processPayment(request: EUDIPaymentRequest): Promise<PaymentResult> {
    // 1. Verify EUDI authentication (SUA/2FA)
    await this.verifyEUDIAuthentication(request.authToken);

    // 2. Parse QR code payment instruction (ISO 20022 format)
    const instruction = this.parseQRCode(request.qrPayload);

    // 3. Get user tier and route payment
    const routeResult = await this.ecnyRouter.routePayment({
      userId: request.userId,
      amount: request.amount,
      currency: request.currency,
      merchantId: request.merchantId,
      scenario: request.currency === 'CNY' ? 'DOMESTIC' : 'OVERSEAS_TOURISM'
    });

    if (!routeResult.allowed) {
      throw new Error(`Payment not allowed: ${routeResult.note}`);
    }

    // 4. Execute payment based on route
    let result: PaymentResult;
    if (request.currency === 'CNY') {
      result = await this.processECNYPayment(request, routeResult);
    } else if (request.currency === 'EUR') {
      result = await this.processSEPAPayment(request, routeResult);
    } else {
      throw new Error(`Unsupported currency: ${request.currency}`);
    }

    // 5. Generate verifiable receipt
    const receiptHash = await this.generateReceipt(result);
    return { ...result, receiptHash };
  }

  private async verifyEUDIAuthentication(authToken: string): Promise<void> {
    if (!authToken.startsWith('EUDI_')) {
      throw new Error('Invalid EUDI authentication token');
    }
    await new Promise(resolve => setTimeout(resolve, 100));
  }

  private parseQRCode(payload: string): any {
    try {
      return JSON.parse(payload);
    } catch {
      throw new Error('Invalid QR code payload');
    }
  }

  private async processECNYPayment(
    request: EUDIPaymentRequest,
    routeResult: RouteResult
  ): Promise<PaymentResult> {
    const instruction = this.iso20022Builder
      .setCurrency('CNY')
      .addPaymentInfo({
        amount: request.amount,
        currency: 'CNY',
        debtor: {
          name: request.userId,
          id: { scheme: 'UTXO', value: `${request.userId}.utxo` }
        },
        creditor: {
          name: request.merchantId,
          id: { scheme: 'UTXO', value: `${request.merchantId}.utxo` }
        },
        purpose: 'GOODS_SERVICES'
      })
      .build();

    return {
      transactionId: `ECNY${Date.now()}${Math.floor(Math.random() * 1000)}`,
      amount: request.amount,
      currency: 'CNY',
      merchantId: request.merchantId,
      userId: request.userId,
      timestamp: new Date(),
      verificationCode: instruction.messageId,
      receiptHash: ''
    };
  }

  private async processSEPAPayment(
    request: EUDIPaymentRequest,
    routeResult: RouteResult
  ): Promise<PaymentResult> {
    const instruction = this.iso20022Builder
      .setCurrency('EUR')
      .addPaymentInfo({
        amount: request.amount,
        currency: 'EUR',
        debtor: {
          name: request.userId,
          id: { scheme: 'UTXO', value: `${request.userId}.utxo` }
        },
        creditor: {
          name: request.merchantId,
          id: { scheme: 'UTXO', value: `${request.merchantId}.utxo` }
        },
        purpose: 'GOODS_SERVICES'
      })
      .build();

    return {
      transactionId: `SEPA${Date.now()}${Math.floor(Math.random() * 1000)}`,
      amount: request.amount,
      currency: 'EUR',
      merchantId: request.merchantId,
      userId: request.userId,
      timestamp: new Date(),
      verificationCode: instruction.messageId,
      receiptHash: ''
    };
  }

  private async generateReceipt(result: PaymentResult): Promise<string> {
    const utxoDns = new UTXODNSResolver();
    return utxoDns.storePRNAudit({
      transactionId: result.transactionId,
      amount: result.amount,
      currency: result.currency,
      merchantId: result.merchantId,
      userId: result.userId,
      timestamp: result.timestamp
    });
  }
}
