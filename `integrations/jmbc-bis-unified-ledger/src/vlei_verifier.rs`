#[cfg(test)]
mod tests {
    use super::*;

    fn create_test_credential(did: &str, status: &str, valid: bool) -> VleiCredential {
        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs();

        VleiCredential {
            id: did.to_string(),
            legal_name: format!("Test Entity {}", did),
            legal_address: "123 Test St, Test City".to_string(),
            jurisdiction: "US".to_string(),
            registration_status: status.to_string(),
            lei: format!("LEI{}", did),
            valid_from: if valid { now - 86400 } else { now + 86400 },
            valid_until: if valid { now + 86400 } else { now + 172800 },
            public_key: "0x1234567890abcdef".to_string(),
            issuer: "did:vlei:issuer".to_string(),
            signature: "signature_123".to_string(),
            attributes: HashMap::new(),
        }
    }

    #[tokio::test]
    async fn test_verify_success() {
        let mut verifier = VleiVerifier::new("https://api.gleif.test".to_string());
        // We need to mock the API call; for this test, we'll use a different approach:
        // We'll directly insert a cached credential to simulate verification.
        let did = "did:vlei:test123";
        let credential = create_test_credential(did, "ACTIVE", true);

        // Insert directly into cache
        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs();
        verifier.cache.insert(
            did.to_string(),
            CachedCredential {
                credential: credential.clone(),
                verified_at: now,
                expires_at: now + 3600,
            },
        );

        let result = verifier.verify(did).await.unwrap();
        assert!(result.valid);
        assert_eq!(result.status, VleiStatus::Active);
        assert_eq!(result.legal_name, "Test Entity did:vlei:test123");
        assert_eq!(result.lei, "LEIdid:vlei:test123");
    }

    #[tokio::test]
    async fn test_verify_inactive() {
        let mut verifier = VleiVerifier::new("https://api.gleif.test".to_string());
        let did = "did:vlei:inactive123";
        let credential = create_test_credential(did, "INACTIVE", true);

        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs();
        verifier.cache.insert(
            did.to_string(),
            CachedCredential {
                credential: credential.clone(),
                verified_at: now,
                expires_at: now + 3600,
            },
        );

        let result = verifier.verify(did).await.unwrap();
        assert!(!result.valid);
        assert_eq!(result.status, VleiStatus::Inactive);
    }

    #[tokio::test]
    async fn test_verify_expired() {
        let mut verifier = VleiVerifier::new("https://api.gleif.test".to_string());
        let did = "did:vlei:expired123";
        let credential = create_test_credential(did, "ACTIVE", false); // valid_from in future

        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs();
        verifier.cache.insert(
            did.to_string(),
            CachedCredential {
                credential: credential.clone(),
                verified_at: now,
                expires_at: now + 3600,
            },
        );

        let result = verifier.verify(did).await;
        // Since it's not yet valid, the verification should fail
        assert!(result.is_err());
        match result {
            Err(VleiError::NotYetValid) => (),
            _ => panic!("Expected NotYetValid error"),
        }
    }

    #[test]
    fn test_to_result() {
        let verifier = VleiVerifier::new("https://api.gleif.test".to_string());
        let credential = create_test_credential("did:vlei:test", "ACTIVE", true);
        let now = 1234567890;

        let result = verifier.to_result(&credential, now);
        assert!(result.valid);
        assert_eq!(result.status, VleiStatus::Active);
        assert_eq!(result.verified_at, now);
        assert_eq!(result.lei, "LEIdid:vlei:test");
        assert!(result.context.contains_key("lei"));
    }

    #[tokio::test]
    async fn test_batch_verify() {
        let mut verifier = VleiVerifier::new("https://api.gleif.test".to_string());

        // Insert some cached credentials
        let did1 = "did:vlei:batch1".to_string();
        let credential1 = create_test_credential(&did1, "ACTIVE", true);
        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs();
        verifier.cache.insert(
            did1.clone(),
            CachedCredential {
                credential: credential1,
                verified_at: now,
                expires_at: now + 3600,
            },
        );

        let did2 = "did:vlei:batch2".to_string();
        let credential2 = create_test_credential(&did2, "INACTIVE", true);
        verifier.cache.insert(
            did2.clone(),
            CachedCredential {
                credential: credential2,
                verified_at: now,
                expires_at: now + 3600,
            },
        );

        let did3 = "did:vlei:batch3".to_string(); // not in cache, will fail fetch

        let results = verifier
            .batch_verify(&[did1.clone(), did2.clone(), did3.clone()])
            .await;

        assert_eq!(results.len(), 3);
        assert!(results.get(&did1).unwrap().valid);
        assert!(!results.get(&did2).unwrap().valid);
        assert!(!results.get(&did3).unwrap().valid); // failed fetch -> invalid
    }

    #[test]
    fn test_cache_operations() {
        let mut verifier = VleiVerifier::new("https://api.gleif.test".to_string());

        // Initially empty
        assert_eq!(verifier.cache_size(), 0);

        // Manually insert
        let did = "did:vlei:cachetest".to_string();
        let credential = create_test_credential(&did, "ACTIVE", true);
        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs();
        verifier.cache.insert(
            did,
            CachedCredential {
                credential,
                verified_at: now,
                expires_at: now + 3600,
            },
        );

        assert_eq!(verifier.cache_size(), 1);

        verifier.clear_cache();
        assert_eq!(verifier.cache_size(), 0);
    }
}
