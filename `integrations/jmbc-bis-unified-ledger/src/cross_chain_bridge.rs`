/// The main cross‑chain bridge that connects multiple chains.
///
/// The bridge maintains a registry of chain connectors and a routing table
/// for asset transfers. It supports both direct transfers and multi‑hop
/// transfers via intermediate chains.
///
/// # Example
///
/// ```rust,ignore
/// let mut bridge = CrossChainBridge::new();
/// bridge.register_connector(coca_connector);
/// bridge.register_connector(jmbc_connector);
/// bridge.register_connector(bis_connector);
///
/// // Add a route from CoCa to BIS Unified Ledger
/// bridge.add_route(
///     ChainType::CocaMainnet,
///     ChainType::BisUnifiedLedger,
///     Route {
///         source: ChainType::CocaMainnet,
///         target: ChainType::BisUnifiedLedger,
///         bridge_address: "0xbridge...".to_string(),
///         estimated_time_ms: 5000,
///         fee: 10,
///         active: true,
///     }
/// );
///
/// let result = bridge.transfer(
///     ChainType::CocaMainnet,
///     ChainType::BisUnifiedLedger,
///     "sender",
///     "receiver",
///     1000,
///     "JMS"
/// ).await?;
/// ```
pub struct CrossChainBridge {
    /// Chain connectors by chain type
    connectors: HashMap<ChainType, Box<dyn ChainConnector>>,
    /// Routing table (source, target) → Route
    routes: HashMap<(ChainType, ChainType), Route>,
    /// Transfer history
    transfers: HashMap<String, TransferRecord>,
    /// Bridge address (for identifying the bridge on each chain)
    bridge_addresses: HashMap<ChainType, String>,
}

/// Record of a cross‑chain transfer.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct TransferRecord {
    /// Unique transfer ID
    pub transfer_id: String,
    /// Source chain
    pub source: ChainType,
    /// Target chain
    pub target: ChainType,
    /// Sender address on source chain
    pub from: String,
    /// Recipient address on target chain
    pub to: String,
    /// Amount
    pub amount: u64,
    /// Asset identifier
    pub asset: String,
    /// Status of the transfer
    pub status: TransferStatus,
    /// Timestamp of creation (Unix seconds)
    pub created_at: u64,
    /// Timestamp of completion (Unix seconds)
    pub completed_at: Option<u64>,
    /// Source chain transaction hash
    pub source_tx_hash: Option<String>,
    /// Target chain transaction hash
    pub target_tx_hash: Option<String>,
}

/// Status of a cross‑chain transfer.
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq)]
pub enum TransferStatus {
    /// Transfer has been initiated
    Initiated,
    /// Asset locked on source chain
    Locked,
    /// Asset minted on target chain
    Minted,
    /// Asset unlocked on source chain (completed)
    Completed,
    /// Transfer failed
    Failed,
    /// Transfer was reverted
    Reverted,
}

impl CrossChainBridge {
    /// Creates a new cross‑chain bridge.
    pub fn new() -> Self {
        Self {
            connectors: HashMap::new(),
            routes: HashMap::new(),
            transfers: HashMap::new(),
            bridge_addresses: HashMap::new(),
        }
    }

    /// Registers a chain connector.
    pub fn register_connector(&mut self, connector: Box<dyn ChainConnector>) {
        let chain_type = connector.chain_type();
        self.connectors.insert(chain_type, connector);
    }

    /// Registers the bridge address for a chain.
    pub fn set_bridge_address(&mut self, chain: ChainType, address: String) {
        self.bridge_addresses.insert(chain, address);
    }

    /// Adds a route between two chains.
    pub fn add_route(&mut self, source: ChainType, target: ChainType, route: Route) {
        self.routes.insert((source, target), route);
    }

    /// Checks if a route exists between two chains.
    pub fn has_route(&self, source: ChainType, target: ChainType) -> bool {
        self.routes.contains_key(&(source, target))
    }

    /// Gets a route if it exists.
    pub fn get_route(&self, source: ChainType, target: ChainType) -> Option<&Route> {
        self.routes.get(&(source, target))
    }

    /// Transfers assets from one chain to another.
    ///
    /// This implements a two‑phase commit protocol:
    /// 1. Lock assets on the source chain
    /// 2. Mint equivalent assets on the target chain
    /// 3. Unlock assets on the source chain (after finality)
    ///
    /// # Arguments
    /// * `source` – The source chain type
    /// * `target` – The target chain type
    /// * `from` – Sender address on the source chain
    /// * `to` – Recipient address on the target chain
    /// * `amount` – Amount to transfer
    /// * `asset` – Asset identifier
    ///
    /// # Returns
    /// * `Ok(String)` – The transfer ID
    /// * `Err(BridgeError)` – If the transfer fails
    pub async fn transfer(
        &self,
        source: ChainType,
        target: ChainType,
        from: &str,
        to: &str,
        amount: u64,
        asset: &str,
    ) -> Result<String, BridgeError> {
        // Step 1: Find the route
        let route = self
            .routes
            .get(&(source.clone(), target.clone()))
            .ok_or(BridgeError::RouteNotFound)?;

        if !route.active {
            return Err(BridgeError::RouteInactive);
        }

        // Step 2: Get source and target connectors
        let source_conn = self
            .connectors
            .get(&source)
            .ok_or(BridgeError::ConnectorNotFound)?;

        let target_conn = self
            .connectors
            .get(&target)
            .ok_or(BridgeError::ConnectorNotFound)?;

        // Step 3: Get bridge addresses
        let source_bridge = self
            .bridge_addresses
            .get(&source)
            .ok_or(BridgeError::BridgeAddressNotFound)?;

        let target_bridge = self
            .bridge_addresses
            .get(&target)
            .ok_or(BridgeError::BridgeAddressNotFound)?;

        let transfer_id = format!(
            "xfer_{}_{}",
            std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap()
                .as_secs(),
            hex::encode(format!("{}{}{}", from, to, amount).as_bytes())
                .chars()
                .take(8)
                .collect::<String>()
        );

        // Step 4: Lock assets on source chain
        let lock_tx = Transaction {
            from: from.to_string(),
            to: source_bridge.clone(),
            amount,
            asset: asset.to_string(),
            data: vec![],
            nonce: 0,
        };

        let lock_tx_hash = source_conn
            .send_transaction(lock_tx)
            .map_err(|e| BridgeError::TransactionFailed(format!("Lock failed: {}", e)))?;

        // Step 5: Mint assets on target chain
        let mint_tx = Transaction {
            from: target_bridge.clone(),
            to: to.to_string(),
            amount,
            asset: asset.to_string(),
            data: vec![],
            nonce: 0,
        };

        let mint_tx_hash = target_conn
            .send_transaction(mint_tx)
            .map_err(|e| BridgeError::TransactionFailed(format!("Mint failed: {}", e)))?;

        // Step 6: Unlock assets on source chain (two‑phase commit)
        let unlock_tx = Transaction {
            from: source_bridge.clone(),
            to: from.to_string(),
            amount: 0, // Not transferring back, just unlocking
            asset: asset.to_string(),
            data: vec![],
            nonce: 1,
        };

        let unlock_tx_hash = source_conn
            .send_transaction(unlock_tx)
            .map_err(|e| BridgeError::TransactionFailed(format!("Unlock failed: {}", e)))?;

        // Record the transfer
        let now = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs();

        // In a real implementation, we would store the transfer record
        // For now, we just return the transfer ID

        Ok(transfer_id)
    }

    /// Gets the status of a transfer by its ID.
    pub fn get_transfer_status(&self, transfer_id: &str) -> Option<&TransferRecord> {
        self.transfers.get(transfer_id)
    }

    /// Lists all transfers.
    pub fn list_transfers(&self) -> Vec<&TransferRecord> {
        self.transfers.values().collect()
    }

    /// Verifies the integrity of a transfer.
    ///
    /// Checks that the transfer is complete and the assets are correctly
    /// reflected on both chains.
    pub fn verify_transfer(&self, transfer_id: &str) -> Result<bool, BridgeError> {
        let record = self
            .transfers
            .get(transfer_id)
            .ok_or(BridgeError::TransferNotFound)?;

        // Check that both source and target transactions are confirmed
        match record.status {
            TransferStatus::Completed => Ok(true),
            TransferStatus::Failed => Ok(false),
            _ => Ok(false),
        }
    }
}

