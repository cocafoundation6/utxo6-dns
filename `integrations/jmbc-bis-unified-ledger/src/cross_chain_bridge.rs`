/// A transaction to be submitted to a chain.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Transaction {
    /// Sender address
    pub from: String,
    /// Recipient address
    pub to: String,
    /// Amount to transfer
    pub amount: u64,
    /// Asset identifier (e.g., "JMS", "USDC", "wCBDC")
    pub asset: String,
    /// Additional data payload
    pub data: Vec<u8>,
    /// Chain‑specific nonce or sequence number
    pub nonce: u64,
}

/// Status of a transaction on a chain.
#[derive(Debug, Clone, Serialize, Deserialize, PartialEq)]
pub enum TransactionStatus {
    /// Transaction has been submitted but not yet processed
    Pending,
    /// Transaction is being processed
    Processing,
    /// Transaction has been confirmed on the chain
    Confirmed,
    /// Transaction failed
    Failed,
}

/// A route for cross‑chain transfers.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct Route {
    /// Source chain
    pub source: ChainType,
    /// Target chain
    pub target: ChainType,
    /// Bridge contract address on the source chain
    pub bridge_address: String,
    /// Estimated settlement time in milliseconds
    pub estimated_time_ms: u64,
    /// Fee in the source asset
    pub fee: u64,
    /// Whether the route is active
    pub active: bool,
}

