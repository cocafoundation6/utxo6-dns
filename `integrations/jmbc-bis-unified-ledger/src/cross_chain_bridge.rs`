//! Cross-Chain Bridge
//!
//! This module provides interoperability between CoCa mainnet, JMBC sidechain,
//! and the BIS Unified Ledger. It enables asset transfers and routing across
//! different blockchain networks and the centralized ledger infrastructure.
//!
//! # Architecture
//!
//! The bridge supports multiple chain types and provides a unified interface
//! for asset transfers. It handles locking assets on the source chain,
//! minting equivalent assets on the target chain, and unlocking assets
//! after settlement finality.
//!
//! # Supported Chains
//! - CoCa Mainnet – Trust anchor and governance
//! - JMBC Sidechain – High‑performance payment settlement
//! - BIS Unified Ledger – Central bank‑level asset settlement
//! - Ethereum – ERC‑20 stablecoins and assets
//! - Bitcoin – UTXO‑based assets
//!
//! # References
//! - CoCa Mainnet Architecture
//! - JMBC Sidechain Specification
//! - BIS Project Agorá – Cross‑chain interoperability

use std::collections::HashMap;
use serde::{Deserialize, Serialize};
use thiserror::Error;

// ============================================================================
// Chain Types
// ============================================================================

/// Supported chain types for cross‑chain transfers.
#[derive(Debug, Clone, PartialEq, Hash, Eq, Serialize, Deserialize)]
pub enum ChainType {
    /// CoCa mainnet (trust anchor)
    CocaMainnet,
    /// JMBC sidechain (payment settlement)
    JmbcSidechain,
    /// BIS Unified Ledger (central bank settlement)
    BisUnifiedLedger,
    /// Ethereum network (ERC‑20 assets)
    Ethereum,
    /// Bitcoin network (UTXO assets)
    Bitcoin,
}

impl std::fmt::Display for ChainType {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            ChainType::CocaMainnet => write!(f, "coca-mainnet"),
            ChainType::JmbcSidechain => write!(f, "jmbc-sidechain"),
            ChainType::BisUnifiedLedger => write!(f, "bis-unified-ledger"),
            ChainType::Ethereum => write!(f, "ethereum"),
            ChainType::Bitcoin => write!(f, "bitcoin"),
        }
    }
}

