#[cfg(test)]
mod tests {
    use super::*;

    fn create_test_bridge() -> CrossChainBridge {
        let mut bridge = CrossChainBridge::new();

        // Register mock connectors
        let coca_conn = Box::new(MockChainConnector::new(ChainType::CocaMainnet));
        let jmbc_conn = Box::new(MockChainConnector::new(ChainType::JmbcSidechain));
        let bis_conn = Box::new(MockChainConnector::new(ChainType::BisUnifiedLedger));

        bridge.register_connector(coca_conn);
        bridge.register_connector(jmbc_conn);
        bridge.register_connector(bis_conn);

        // Set bridge addresses
        bridge.set_bridge_address(ChainType::CocaMainnet, "0xCocaBridge".to_string());
        bridge.set_bridge_address(ChainType::JmbcSidechain, "0xJmbcBridge".to_string());
        bridge.set_bridge_address(ChainType::BisUnifiedLedger, "0xBisBridge".to_string());

        // Add routes
        let route_coca_jmbc = Route {
            source: ChainType::CocaMainnet,
            target: ChainType::JmbcSidechain,
            bridge_address: "0xCocaJmbcBridge".to_string(),
            estimated_time_ms: 2000,
            fee: 5,
            active: true,
        };
        bridge.add_route(ChainType::CocaMainnet, ChainType::JmbcSidechain, route_coca_jmbc);

        let route_coca_bis = Route {
            source: ChainType::CocaMainnet,
            target: ChainType::BisUnifiedLedger,
            bridge_address: "0xCocaBisBridge".to_string(),
            estimated_time_ms: 5000,
            fee: 10,
            active: true,
        };
        bridge.add_route(ChainType::CocaMainnet, ChainType::BisUnifiedLedger, route_coca_bis);

        bridge
    }

    #[tokio::test]
    async fn test_transfer_coca_to_jmbc() {
        let bridge = create_test_bridge();

        let result = bridge
            .transfer(
                ChainType::CocaMainnet,
                ChainType::JmbcSidechain,
                "0xSender",
                "0xReceiver",
                1000,
                "JMS",
            )
            .await;

        assert!(result.is_ok());
        let transfer_id = result.unwrap();
        assert!(transfer_id.starts_with("xfer_"));
    }

    #[tokio::test]
    async fn test_transfer_coca_to_bis() {
        let bridge = create_test_bridge();

        let result = bridge
            .transfer(
                ChainType::CocaMainnet,
                ChainType::BisUnifiedLedger,
                "0xSender",
                "0xReceiver",
                5000,
                "wCBDC",
            )
            .await;

        assert!(result.is_ok());
    }

    #[tokio::test]
    async fn test_transfer_route_not_found() {
        let bridge = create_test_bridge();

        let result = bridge
            .transfer(
                ChainType::JmbcSidechain,
                ChainType::Bitcoin, // No route exists
                "0xSender",
                "0xReceiver",
                100,
                "BTC",
            )
            .await;

        assert!(result.is_err());
        match result {
            Err(BridgeError::RouteNotFound) => (),
            _ => panic!("Expected RouteNotFound error"),
        }
    }

    #[tokio::test]
    async fn test_has_route() {
        let bridge = create_test_bridge();

        assert!(bridge.has_route(ChainType::CocaMainnet, ChainType::JmbcSidechain));
        assert!(bridge.has_route(ChainType::CocaMainnet, ChainType::BisUnifiedLedger));
        assert!(!bridge.has_route(ChainType::JmbcSidechain, ChainType::CocaMainnet));
        assert!(!bridge.has_route(ChainType::Ethereum, ChainType::Bitcoin));
    }

    #[tokio::test]
    async fn test_get_route() {
        let bridge = create_test_bridge();

        let route = bridge.get_route(ChainType::CocaMainnet, ChainType::JmbcSidechain);
        assert!(route.is_some());
        let route = route.unwrap();
        assert_eq!(route.fee, 5);
        assert_eq!(route.estimated_time_ms, 2000);
        assert!(route.active);

        let route = bridge.get_route(ChainType::CocaMainnet, ChainType::BisUnifiedLedger);
        assert!(route.is_some());
        let route = route.unwrap();
        assert_eq!(route.fee, 10);
        assert_eq!(route.estimated_time_ms, 5000);
    }

    #[test]
    fn test_mock_connector() {
        let mut connector = MockChainConnector::new(ChainType::Ethereum);
        connector.set_balance("0xAlice", "USDC", 10000);
        connector.set_balance("0xBob", "USDC", 5000);

        assert_eq!(connector.get_balance("0xAlice", "USDC").unwrap(), 10000);
        assert_eq!(connector.get_balance("0xBob", "USDC").unwrap(), 5000);
        assert_eq!(connector.get_balance("0xCharlie", "USDC").unwrap(), 0);

        let tx = Transaction {
            from: "0xAlice".to_string(),
            to: "0xBob".to_string(),
            amount: 100,
            asset: "USDC".to_string(),
            data: vec![],
            nonce: 0,
        };
        let tx_hash = connector.send_transaction(tx).unwrap();
        assert!(tx_hash.contains("ethereum_tx_"));
    }

    #[test]
    fn test_display_chain_type() {
        assert_eq!(format!("{}", ChainType::CocaMainnet), "coca-mainnet");
        assert_eq!(format!("{}", ChainType::JmbcSidechain), "jmbc-sidechain");
        assert_eq!(format!("{}", ChainType::BisUnifiedLedger), "bis-unified-ledger");
        assert_eq!(format!("{}", ChainType::Ethereum), "ethereum");
        assert_eq!(format!("{}", ChainType::Bitcoin), "bitcoin");
    }
}
