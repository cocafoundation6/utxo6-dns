/// A connector that interacts with a specific blockchain or ledger.
pub trait ChainConnector: Send + Sync {
    /// Returns the chain type this connector handles.
    fn chain_type(&self) -> ChainType;

    /// Gets the balance of an address for a specific asset.
    fn get_balance(&self, address: &str, asset: &str) -> Result<u64, String>;

    /// Submits a transaction to the chain.
    fn send_transaction(&self, tx: Transaction) -> Result<String, String>;

    /// Gets the status of a transaction by its hash.
    fn get_transaction(&self, tx_hash: &str) -> Result<TransactionStatus, String>;

    /// Gets the latest block height.
    fn get_block_height(&self) -> Result<u64, String>;
}

