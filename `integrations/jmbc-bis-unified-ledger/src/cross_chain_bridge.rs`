/// A mock connector for testing and development.
pub struct MockChainConnector {
    chain_type: ChainType,
    balances: HashMap<String, u64>,
    tx_log: HashMap<String, TransactionStatus>,
}

impl MockChainConnector {
    pub fn new(chain_type: ChainType) -> Self {
        Self {
            chain_type,
            balances: HashMap::new(),
            tx_log: HashMap::new(),
        }
    }

    pub fn set_balance(&mut self, address: &str, asset: &str, balance: u64) {
        self.balances
            .insert(format!("{}:{}", address, asset), balance);
    }
}

impl ChainConnector for MockChainConnector {
    fn chain_type(&self) -> ChainType {
        self.chain_type.clone()
    }

    fn get_balance(&self, address: &str, asset: &str) -> Result<u64, String> {
        let key = format!("{}:{}", address, asset);
        Ok(*self.balances.get(&key).unwrap_or(&0))
    }

    fn send_transaction(&self, tx: Transaction) -> Result<String, String> {
        let tx_hash = format!(
            "{}_tx_{}",
            self.chain_type(),
            std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap()
                .as_secs()
        );
        Ok(tx_hash)
    }

    fn get_transaction(&self, tx_hash: &str) -> Result<TransactionStatus, String> {
        Ok(TransactionStatus::Confirmed)
    }

    fn get_block_height(&self) -> Result<u64, String> {
        Ok(12345678)
    }
}

