/// Errors that can occur during cross‑chain operations.
#[derive(Error, Debug)]
pub enum BridgeError {
    #[error("Route not found for the specified chain pair")]
    RouteNotFound,

    #[error("Route is inactive")]
    RouteInactive,

    #[error("Chain connector not found")]
    ConnectorNotFound,

    #[error("Bridge address not found for chain")]
    BridgeAddressNotFound,

    #[error("Transaction failed: {0}")]
    TransactionFailed(String),

    #[error("Transfer not found")]
    TransferNotFound,

    #[error("Insufficient balance on source chain")]
    InsufficientBalance,

    #[error("Asset not supported")]
    AssetNotSupported,
}

