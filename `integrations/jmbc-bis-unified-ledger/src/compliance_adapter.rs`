/// Errors that can occur during compliance operations.
#[derive(Error, Debug)]
pub enum ComplianceError {
    #[error("PRN node unreachable")]
    PrnUnreachable,

    #[error("Compliance check failed: {0}")]
    CheckFailed(String),

    #[error("Audit chain verification failed")]
    AuditChainInvalid,

    #[error("Transaction not found in audit log")]
    TransactionNotFound,
}

