#[cfg(test)]
mod tests {
    use super::*;

    fn create_test_adapter() -> PrnComplianceAdapter {
        PrnComplianceAdapter::new(
            "https://prn.test".to_string(),
            "test-node-001".to_string(),
        )
    }

    fn create_test_request(transaction_id: &str) -> PrnComplianceRequest {
        let mut metadata = HashMap::new();
        metadata.insert("test".to_string(), "value".to_string());

        PrnComplianceRequest {
            transaction_id: transaction_id.to_string(),
            payer_domain: "payer.utxo".to_string(),
            payee_domain: "payee.utxo".to_string(),
            amount: 1_000_000,
            currency: "USD".to_string(),
            timestamp: std::time::SystemTime::now()
                .duration_since(std::time::UNIX_EPOCH)
                .unwrap()
                .as_secs(),
            metadata,
        }
    }

    #[tokio::test]
    async fn test_check_compliance() {
        let mut adapter = create_test_adapter();
        let request = create_test_request("tx_001");

        let result = adapter.check_compliance(request.clone()).await;

        // In a real environment with a PRN node, this would succeed.
        // For now, it might fail if the test endpoint is not available.
        // We'll test the structure regardless.

        if let Ok(response) = result {
            assert_eq!(response.status, PrnComplianceStatus::Approved);
            assert!(response.risk_score >= 0.0 && response.risk_score <= 1.0);
            assert!(!response.audit_hash.is_empty());
            assert_eq!(adapter.audit_entry_count(), 1);
        } else {
            // If it fails, at least ensure the adapter is in a consistent state
            assert_eq!(adapter.audit_entry_count(), 0);
        }
    }

    #[tokio::test]
    async fn test_audit_log_chain() {
        let mut adapter = create_test_adapter();

        // Add some entries
        let tx1 = create_test_request("tx_001");
        let tx2 = create_test_request("tx_002");

        let _ = adapter.check_compliance(tx1).await.ok();
        let _ = adapter.check_compliance(tx2).await.ok();

        // Verify the chain
        assert!(adapter.verify_audit_chain());

        // Check PRNAUDIT RR generation
        let rr = adapter.generate_prnaudit_rr("tx_001");
        if let Some(rr_record) = rr {
            assert!(rr_record.starts_with("PRNAUDIT tx_001"));
        }

        // Check chain generation
        let chain = adapter.generate_prnaudit_chain("tx_001");
        if !chain.is_empty() {
            assert_eq!(chain.len(), 1);
        }
    }

    #[test]
    fn test_audit_chain_verification() {
        let adapter = create_test_adapter();
        // Empty chain should be valid
        assert!(adapter.verify_audit_chain());
    }

    #[tokio::test]
    async fn test_prnaudit_rr_generation() {
        let mut adapter = create_test_adapter();
        let request = create_test_request("tx_prnaudit");

        let _ = adapter.check_compliance(request).await.ok();

        let rr = adapter.generate_prnaudit_rr("tx_prnaudit");
        if let Some(rr_record) = rr {
            // Format: "PRNAUDIT <tx_id> <event_type> <prev_hash> <signature> <timestamp>"
            let parts: Vec<&str> = rr_record.split_whitespace().collect();
            assert_eq!(parts.len(), 6);
            assert_eq!(parts[0], "PRNAUDIT");
            assert_eq!(parts[1], "tx_prnaudit");
        }

        let chain = adapter.generate_prnaudit_chain("tx_prnaudit");
        assert!(chain.len() <= 1);
    }

    #[test]
    fn test_audit_entry_count() {
        let adapter = create_test_adapter();
        // Initially empty
        assert_eq!(adapter.audit_entry_count(), 0);

        // We can't easily test non-empty count without a mock PRN node,
        // but the method is trivial.
    }
}
