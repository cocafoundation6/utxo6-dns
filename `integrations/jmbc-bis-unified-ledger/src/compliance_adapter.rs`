/// Request sent to the PRN node for compliance checking.
#[derive(Debug, Clone, Serialize, Deserialize)]
pub struct PrnComplianceRequest {
    /// Unique transaction identifier
    pub transaction_id: String,
    /// Payer's `.utxo` domain
    pub payer_domain: String,
    /// Payee's `.utxo` domain
    pub payee_domain: String,
    /// Transaction amount
    pub amount: u64,
    /// Currency code
    pub currency: String,
    /// Timestamp of the request (Unix seconds)
    pub timestamp: u64,
    /// Additional metadata for compliance checks
    pub metadata: HashMap<String, String>,
}

/// Response from the PRN node.
#[derive(Debug, Clone, Deserialize, Serialize)]
pub struct PrnComplianceResponse {
    /// Approval status
    pub status: PrnComplianceStatus,
    /// Risk score (0.0 to 1.0)
    pub risk_score: f64,
    /// PRNAUDIT RR hash for this check
    pub audit_hash: String,
    /// Whether manual review is required
    pub requires_manual_review: bool,
    /// Additional notes from the PRN node
    pub notes: Option<String>,
}

/// Compliance status returned by the PRN node.
#[derive(Debug, Clone, Deserialize, Serialize, PartialEq)]
pub enum PrnComplianceStatus {
    /// Transaction is compliant and approved
    Approved,
    /// Transaction is rejected due to compliance rules
    Rejected,
    /// Transaction requires manual regulatory review
    PendingReview,
}

/// An audit log entry forming an immutable chain (PRNAUDIT RR).
#[derive(Debug, Clone, Serialize, Deserialize)]
