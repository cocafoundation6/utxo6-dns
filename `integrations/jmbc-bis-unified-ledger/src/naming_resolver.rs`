mod tests {
    use super::*;
    use crate::ledger_connector::{UnifiedLedgerConnector, ParticipantType};

    fn create_test_connector() -> UnifiedLedgerConnector {
        UnifiedLedgerConnector::new("https://api.bis-unified-ledger.test".to_string())
    }

    #[tokio::test]
    async fn test_resolve_central_bank() {
        let connector = create_test_connector();
        let mut resolver = UnifiedLedgerNamingResolver::new(connector);

        // This will fail because no participants are registered, but we can test
        // the error path.
        let result = resolver.resolve("fed.utxo").await;
        // In a real environment with registered participants, this would succeed.
        // For now, it should return an error.
        assert!(result.is_err());
    }

    #[test]
    fn test_determine_asset_type() {
        let connector = create_test_connector();
        let resolver = UnifiedLedgerNamingResolver::new(connector);

        let participant_cb = UnifiedLedgerParticipant {
            id: "cb_1".to_string(),
            name: "Central Bank".to_string(),
            participant_type: ParticipantType::CentralBank,
            jurisdiction: "US".to_string(),
            vlei_did: None,
            utxo_domain: Some("fed.utxo".to_string()),
            ledger_address: "0x123".to_string(),
        };

        let record = UtxoRecord {
            domain: "fed.utxo".to_string(),
            owner: "owner".to_string(),
            endpoint_id: "0x456".to_string(),
            vrf_proof: None,
            vlei_did: None,
            compliance_ref: None,
        };

        let asset = resolver.determine_asset_type(&participant_cb, &record);
        assert_eq!(asset, UnifiedLedgerAsset::Wbcdc);

        let participant_commercial = UnifiedLedgerParticipant {
            id: "com_1".to_string(),
            name: "Commercial Bank".to_string(),
            participant_type: ParticipantType::CommercialBank,
            jurisdiction: "US".to_string(),
            vlei_did: None,
            utxo_domain: Some("bank.utxo".to_string()),
            ledger_address: "0x789".to_string(),
        };

        let asset = resolver.determine_asset_type(&participant_commercial, &record);
        assert_eq!(asset, UnifiedLedgerAsset::TokenizedDeposit);

        let participant_fi = UnifiedLedgerParticipant {
            id: "fi_1".to_string(),
            name: "Investment Firm".to_string(),
            participant_type: ParticipantType::FinancialInstitution,
            jurisdiction: "GB".to_string(),
            vlei_did: None,
            utxo_domain: Some("fund.utxo".to_string()),
            ledger_address: "0xabc".to_string(),
        };

        let record_bond = UtxoRecord {
            domain: "fund.utxo".to_string(),
            owner: "owner".to_string(),
            endpoint_id: "bond_gilt".to_string(),
            vrf_proof: None,
            vlei_did: None,
            compliance_ref: None,
        };

        let asset = resolver.determine_asset_type(&participant_fi, &record_bond);
        assert_eq!(asset, UnifiedLedgerAsset::TokenizedBond);

        let record_rwa = UtxoRecord {
            domain: "fund.utxo".to_string(),
            owner: "owner".to_string(),
            endpoint_id: "rwa_gold".to_string(),
            vrf_proof: None,
            vlei_did: None,
            compliance_ref: None,
        };

        let asset = resolver.determine_asset_type(&participant_fi, &record_rwa);
        assert_eq!(asset, UnifiedLedgerAsset::RwaToken);
    }

    #[tokio::test]
    async fn test_cache_invalidation() {
        let connector = create_test_connector();
        let mut resolver = UnifiedLedgerNamingResolver::new(connector);

        // Resolve (will fail, but we can still test cache operations)
        let _ = resolver.resolve("test.utxo").await;

        // Cache size should be 0 because resolution failed
        assert_eq!(resolver.cache_size(), 0);

        // Manually insert a fake entry to test invalidation
        let fake_resolution = NamingResolution {
            domain: "fake.utxo".to_string(),
            participant: UnifiedLedgerParticipant {
                id: "fake".to_string(),
                name: "Fake".to_string(),
                participant_type: ParticipantType::CentralBank,
                jurisdiction: "US".to_string(),
                vlei_did: None,
                utxo_domain: Some("fake.utxo".to_string()),
                ledger_address: "0x000".to_string(),
            },
            asset_type: UnifiedLedgerAsset::Wbcdc,
            asset_address: "0x000".to_string(),
            vlei_verified: false,
            compliance_status: ComplianceStatus::Verified,
            vrf_proof: None,
        };

        resolver.cache.insert(
            "fake.utxo".to_string(),
            CachedResolution {
                resolution: fake_resolution,
                expires_at: u64::MAX,
            },
        );

        assert_eq!(resolver.cache_size(), 1);
        resolver.invalidate("fake.utxo");
        assert_eq!(resolver.cache_size(), 0);
    }
