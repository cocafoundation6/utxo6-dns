/// Register participants on the BIS Unified Ledger.
///
/// This is a helper function that would be used in production to register
/// participants before performing cross‑border payments.
///
/// # Arguments
/// * `connector` – The ledger connector
/// * `participants` – A slice of participants to register
///
/// # Returns
/// A vector of participant IDs that were successfully registered.
#[allow(dead_code)]
async fn register_participants(
    connector: &mut UnifiedLedgerConnector,
    participants: &[UnifiedLedgerParticipant],
) -> Vec<String> {
    let mut registered = Vec::new();
    for participant in participants {
        match connector.register_participant(participant.clone()).await {
            Ok(id) => {
                registered.push(id);
                println!("   ✅ Registered: {}", participant.name);
            }
            Err(e) => {
                println!("   ❌ Failed to register {}: {}", participant.name, e);
            }
        }
    }
    registered
}

/// Perform a complete compliance check with retry logic.
///
/// # Arguments
/// * `adapter` – The PRN compliance adapter
/// * `request` – The compliance check request
/// * `max_retries` – Maximum number of retries on failure
///
/// # Returns
/// The compliance response if successful, or an error.
#[allow(dead_code)]
async fn compliance_check_with_retry(
    adapter: &mut PrnComplianceAdapter,
    request: &PrnComplianceRequest,
    max_retries: u32,
) -> Result<PrnComplianceStatus, Box<dyn std::error::Error>> {
    let mut retries = 0;
    while retries < max_retries {
        match adapter.check_compliance(request.clone()).await {
            Ok(response) => return Ok(response.status),
            Err(_) => {
                retries += 1;
                if retries < max_retries {
                    tokio::time::sleep(tokio::time::Duration::from_millis(500 * retries as u64)).await;
                }
            }
        }
    }
    Err("Max retries exceeded".into())
}

/// Generate a comprehensive audit summary for a transaction.
///
/// This function aggregates all audit entries for a transaction into a
/// single summary report.
#[allow(dead_code)]
fn generate_audit_summary(
    adapter: &PrnComplianceAdapter,
    transaction_id: &str,
) -> serde_json::Value {
    let entries = adapter.get_audit_entries(transaction_id);
    serde_json::json!({
        "transaction_id": transaction_id,
        "entry_count": entries.len(),
        "status": if !entries.is_empty() { "COMPLIANT" } else { "NO_RECORDS" },
        "entries": entries.iter().map(|e| {
            serde_json::json!({
                "event_type": e.event_type,
                "timestamp": e.timestamp,
                "prn_node": e.prn_node_id,
            })
        }).collect::<Vec<_>>(),
    })
}
