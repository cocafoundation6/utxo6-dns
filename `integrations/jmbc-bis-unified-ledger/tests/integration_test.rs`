    #[tokio::test]
    async fn test_cross_chain_bridge_transfer() {
        let mut bridge = CrossChainBridge::new();

        // Register mock connectors
        let coca_conn = Box::new(MockChainConnector::new(ChainType::CocaMainnet));
        let jmbc_conn = Box::new(MockChainConnector::new(ChainType::JmbcSidechain));

        bridge.register_connector(coca_conn);
        bridge.register_connector(jmbc_conn);

        // Set bridge addresses
        bridge.set_bridge_address(ChainType::CocaMainnet, "0xCocaBridge".to_string());
        bridge.set_bridge_address(ChainType::JmbcSidechain, "0xJmbcBridge".to_string());

        // Add a route
        let route = Route {
            source: ChainType::CocaMainnet,
            target: ChainType::JmbcSidechain,
            bridge_address: "0xCocaJmbcBridge".to_string(),
            estimated_time_ms: 2000,
            fee: 5,
            active: true,
        };
        bridge.add_route(ChainType::CocaMainnet, ChainType::JmbcSidechain, route);

        // Perform transfer
        let result = bridge
            .transfer(
                ChainType::CocaMainnet,
                ChainType::JmbcSidechain,
                "0xSender",
                "0xReceiver",
                1000,
                "JMS",
            )
            .await;

        assert!(result.is_ok());
        let transfer_id = result.unwrap();
        assert!(transfer_id.starts_with("xfer_"));
    }

