    #[tokio::test]
    async fn test_end_to_end_cross_border_payment() {
        // This test simulates a complete cross-border payment flow:
        // 1. Resolve payer and payee .utxo domains
        // 2. Perform PRN compliance check
        // 3. Execute atomic settlement
        // 4. Bridge the settled assets to another chain

        // We'll use the actual components, but with mock endpoints.
        // Since we don't have real infrastructure, we'll test the flow
        // at a high level, expecting errors, but ensuring the code paths
        // are exercised.

        let connector = create_test_connector();
        let mut resolver = UnifiedLedgerNamingResolver::new(connector.clone());

        // Step 1: Resolve domains (will fail, but that's okay)
        let payer_res = resolver.resolve("bank-a.utxo").await;
        let payee_res = resolver.resolve("bank-b.utxo").await;
        assert!(payer_res.is_err());
        assert!(payee_res.is_err());

        // Step 2: Compliance check (will fail)
        let mut prn_adapter = PrnComplianceAdapter::new(
            "https://prn.test".to_string(),
            "test-node".to_string(),
        );
        let comp_req = PrnComplianceRequest {
            transaction_id: "e2e_001".to_string(),
            payer_domain: "bank-a.utxo".to_string(),
            payee_domain: "bank-b.utxo".to_string(),
            amount: 1_000_000,
            currency: "USD".to_string(),
            timestamp: now(),
            metadata: HashMap::new(),
        };
        let comp_res = prn_adapter.check_compliance(comp_req).await;
        assert!(comp_res.is_err());

        // Step 3: Atomic settlement (will fail)
        let mut settlement = AtomicSettlementTrigger::new(connector);
        let settle_req = AtomicSettlementRequest {
            settlement_id: "e2e_stl_001".to_string(),
            payer: "bank-a.utxo".to_string(),
            payee: "bank-b.utxo".to_string(),
            amount: 1_000_000,
            currency: "USD".to_string(),
            target_currency: Some("EUR".to_string()),
            conditions: vec![
                SettlementCondition {
                    condition_type: ConditionType::CompliancePassed,
                    value: "true".to_string(),
                },
            ],
            timeout_ms: 5000,
            metadata: HashMap::new(),
        };
        let settle_res = settlement.initiate_settlement(settle_req).await;
        assert!(settle_res.is_err());

        // Step 4: Cross-chain bridge (we can test separately)
        let mut bridge = CrossChainBridge::new();
        let coca_conn = Box::new(MockChainConnector::new(ChainType::CocaMainnet));
        let jmbc_conn = Box::new(MockChainConnector::new(ChainType::JmbcSidechain));
        bridge.register_connector(coca_conn);
        bridge.register_connector(jmbc_conn);
        bridge.set_bridge_address(ChainType::CocaMainnet, "0xBridgeCoca".to_string());
        bridge.set_bridge_address(ChainType::JmbcSidechain, "0xBridgeJmbc".to_string());
        let route = Route {
            source: ChainType::CocaMainnet,
            target: ChainType::JmbcSidechain,
            bridge_address: "0xRouteBridge".to_string(),
            estimated_time_ms: 2000,
            fee: 5,
            active: true,
        };
        bridge.add_route(ChainType::CocaMainnet, ChainType::JmbcSidechain, route);
        let bridge_res = bridge
            .transfer(
                ChainType::CocaMainnet,
                ChainType::JmbcSidechain,
                "0xSender",
                "0xReceiver",
                1000,
                "JMS",
            )
            .await;
        assert!(bridge_res.is_ok());

        // This test primarily ensures that the code compiles and runs
        // through the main paths without panics.
    }

