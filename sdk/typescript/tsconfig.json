  subDomain: string;
  publicKey: string;
  ownerAddress: Address;
  ttl?: number;             // TTLCache Time
}

/**
 * Domain Module – Provides DNS resolution and domain management 
*/
export namespace Domain {
  /**
   * Get the main domain of the current agent   
* Read the current agent identity from the TEE environment   
*/
  export async function getCurrentDomain(): Promise<string> {
// Implementation: Read from TEE-protected storage    
return Promise.resolve('agent.utxo');
  }

  /**
   * Analyze DID as a domain component   
* @param did - format: did:coca:example.utxo of did:coca:sub.example.utxo:1
   */
  export async function resolveDid(did: string): Promise<ResolveResult> {
 // Implementation: Parse the DID string and query the on-chain domain registry
// Reference: Three-layer global distributed resolution network L2 regional node    
const parsed = parseDID(did);
    const record = await queryUTXORR(parsed.domain);
    return {
      domain: parsed.domain,
      subDomain: parsed.subDomain,
      agentIndex: parsed.agentIndex,
      owner: record.owner,
      endpointId: record.endpointId,
      vrfProof: record.vrfProof,
      vleiDID: record.vleiDID
    };
  }

  /**
   * Query Domain Owner
   * @param domain - Full domain name or subdomain
   */
  export async function getOwner(domain: string): Promise<Address> {
    const record = await queryUTXORR(domain);
    return record.owner;
  }

  /**
   * Check if the domain name has expired   
*/
  export async function isExpired(domain: string): Promise<boolean> {
    const record = await queryUTXORR(domain);
    if (!record.expiry) return false;
    return record.expiry < Date.now();
  }

  /**
   * Register Subdomain (Created by Agent)   
* @param subDomain -  Subdomain   
* @param publicKey - Agent Public Key   
*/
  export async function registerSubDomain(
    subDomain: string,
