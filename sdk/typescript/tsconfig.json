// Domain Module - Domain Resolution & DID Management
// Based on the IETF draft-guorong-utxo-dns-01 specification
import { Address, DomainHash, AgentIndex } from '../types';

/**
 * Domain Resolution Results 
*/
export interface ResolveResult {
  domain: string;
  subDomain?: string;
  agentIndex?: number;
  owner: Address;
  endpointId: string;        //  Payment endpoint in UTXORR  
vrfProof?: string;        // VRF Proof (Optional)
  vleiDID?: string;         // vLEIstatus of a legal person 
}

/**
 * Domain Name Registration Request 
*/
