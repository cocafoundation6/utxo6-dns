### 2.5 Example: Automatic Payment Agent

**Path**: `sdk/examples/auto-payment-agent/index.ts`

```typescript
// Auto Payment Agent Example
//Display: Domain Binding, VC Authorization, Automatic Payment, Data Persistence

import { Domain, Agent, Payment, VC, Vault, Log } from '@coca/sdk';

interface AutoPaymentConfig {
  maxAmountPerDay: number;
  allowedRecipients: string[];
  autoPayEnabled: boolean;
}

export class AutoPaymentAgent {
  private config: AutoPaymentConfig;

  constructor(config: AutoPaymentConfig) {
    this.config = config;
    Log.info('   AutoPaymentAgent Initialization completed');
  }

  /**
   * Process the payment request   
*/
  async handle(request: PaymentRequest): Promise<PaymentResponse> {
    Log.debug(`   Received payment request: ${JSON.stringify(request)}`);

    // 1. Check if the recipient is on the whitelist
    if (!this.config.allowedRecipients.includes(request.to)) {
      Log.warn(`❌ The recipient is not on the whitelist: ${request.to}`);
      return { success: false, reason: 'recipient_not_allowed' };
    }

// 2. Check if automatic payment is enabled    
if (!this.config.autoPayEnabled) {
      Log.warn('  Auto-payment is not enabled');
      return { success: false, reason: 'auto_pay_disabled' };
    }

    // 3. Get today's total pay（Read from Vault）
    const todayKey = `day_${new Date().toISOString().slice(0, 10)}`;
    const paidTodayData = await Vault.get(todayKey);
    const paidToday = paidTodayData 
      ? parseInt(new TextDecoder().decode(paidTodayData)) 
      : 0 ;

    if (paidToday + request.amount > this.config.maxAmountPerDay) {
      Log.warn(` Daily limit exceeded: ${paidToday} + ${request.amount} > ${this.config.maxAmountPerDay}`);
      return { success: false, reason: 'daily_limit_exceeded' };
    }

// 4. Get the current agent identity    
const agentDid = await Agent.getDid();
    Log.info(`   Intelligent agent: ${agentDid}`);

    // 5. validate VC authorize
    const vc = await VC.getCredential(agentDid, 'payment_authorization');
    if (!vc || vc.capabilities.maxAmount < request.amount) {
      Log.warn(`   VCAuthorizations insufficient: max ${vc?.capabilities.maxAmount || 0}`);
      return { success: false, reason: 'insufficient_authorization' };
    }

// 6.Process Payment    
const result = await Payment.transfer({
      to: request.to,
      amount: request.amount,
      scene: request.scene || 'auto_payment'
    });

    if (result.success) {
      // Total updates for today
      await Vault.put(todayKey, new TextEncoder().encode(String(paidToday + request.amount)));
      Log.info(`✅  pay success: ${result.txHash}`);
    } else {
      Log.error(`❌ Pay failed: ${result.reason}`);
    }

    return result;
  }
}

//  main entry door 
async function main() {
  const agent = new AutoPaymentAgent({
    maxAmountPerDay: 1000,
    allowedRecipients: ['merchant.utxo', 'did:coca:supplier.utxo'],
    autoPayEnabled: true
  });

  // Registered Domain Name
  await Domain.registerSubDomain('payment-bot', await Agent.getPublicKey());
  
  // Waiting for payment request...
  Log.info('  Agent is ready, awaiting payment request.');
}

if (require.main === module) if (require.main === module) {
  main().catch(console.error);  main().catch(console.error);
}
``````

