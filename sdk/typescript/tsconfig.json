  }

  /**
   * Query UTXO RR records
   * Core: Invoke the DNS resolver to retrieve the UTXO RR (Record Type 260).

   */
  async function queryUTXORR(domain: string): Promise<any> {
    // mplementation: Query UTXO RR via DNS over HTTPS

    // consult IETF draft-guorong-utxo-dns-01
    const response = await fetch(`https://dns.utxo/dns-query?name=${domain}&type=260`);
    return response.json();
  }

