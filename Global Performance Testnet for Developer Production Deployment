### 3.4 Deployment Script (`testnet/scripts/deploy-testnet.sh`)

```bash
#!/bin/bash
# Author: J. Tian (uw2icg-core)
# One-click deployment of the Global Performance Testnet

set -e

echo "🚀 UTXO6-DNS Global Performance Testnet Deployment Script"
echo "========================================================"

command -v docker >/dev/null 2>&1 || { echo "❌ Docker is not installed"; exit 1; }
command -v kubectl >/dev/null 2>&1 || { echo "⚠️  kubectl not found. Using Docker Compose."; USE_K8S=false; }

if [ "$USE_K8S" != "false" ]; then
  echo "📦 Kubernetes detected. Deploying to cluster..."
  kubectl apply -f testnet/kubernetes/
  kubectl rollout status deployment/test-orchestrator -n utxo-testnet
  kubectl rollout status deployment/test-node -n utxo-testnet
  kubectl port-forward svc/grafana 3000:3000 -n utxo-testnet &
else
  echo "🐳 Using Docker Compose for local deployment..."
  cd testnet
  docker-compose up -d --build
  cd ..
fi

echo "⏳ Waiting for services to be ready..."
sleep 10

echo "🔬 Running benchmark tests..."
npm run benchmark:testnet

echo ""
echo "✅ Deployment complete!"
echo "📊 Grafana: http://localhost:3000 (admin/admin)"
echo "📈 Orchestrator API: http://localhost:3005"
echo "🌐 Test Node US: http://localhost:8081"
echo "🌐 Test Node EU: http://localhost:8082"
echo "🌐 Test Node ASIA: http://localhost:8083"
```

