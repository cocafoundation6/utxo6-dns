## 3. Core Component Design & Code

### 3.1 Test Orchestrator (`testnet/orchestrator/src/scheduler.ts`)

```typescript
// Author: J. Tian (uw2icg-core)

export interface TestTask {
  id: string;
  type: 'vrf' | 'dns_resolve' | 'multi_chain' | 'prn_audit';
  target: string;          // Target .utxo domain node
  payload: any;
  iterations: number;
  timeout: number;         // Milliseconds
}

export interface TestResult {
  taskId: string;
  nodeId: string;
  success: boolean;
  latency: number;         // Average latency (ms)
  p95: number;             // 95th percentile latency
  p99: number;             // 99th percentile latency
  throughput: number;      // Requests per second
  errors: number;
  timestamp: Date;
  details?: any;
}

export class TestScheduler {
  private tasks: Map<string, TestTask> = new Map();
  private results: TestResult[] = [];

  registerTask(task: TestTask): void {
    this.tasks.set(task.id, task);
    console.log(`[Scheduler] Registered task: ${task.id} (${task.type})`);
  }

  async dispatchTask(taskId: string, nodeEndpoint: string): Promise<TestResult> {
    const task = this.tasks.get(taskId);
    if (!task) throw new Error(`Task ${taskId} not found`);

    const startTime = Date.now();
    let successCount = 0;
    let errorCount = 0;
    const latencies: number[] = [];

    for (let i = 0; i < task.iterations; i++) {
      try {
        const start = performance.now();
        await this.executeTask(task, nodeEndpoint);
        const end = performance.now();
        latencies.push(end - start);
        successCount++;
      } catch (err) {
        errorCount++;
      }
    }

    const totalTime = Date.now() - startTime;
    const sortedLatencies = latencies.sort((a, b) => a - b);

    const result: TestResult = {
      taskId,
      nodeId: nodeEndpoint,
      success: errorCount === 0,
      latency: latencies.reduce((a, b) => a + b, 0) / (latencies.length || 1),
      p95: sortedLatencies[Math.floor(sortedLatencies.length * 0.95)] || 0,
      p99: sortedLatencies[Math.floor(sortedLatencies.length * 0.99)] || 0,
      throughput: successCount / (totalTime / 1000),
      errors: errorCount,
      timestamp: new Date(),
    };

    this.results.push(result);
    return result;
  }

  private async executeTask(task: TestTask, endpoint: string): Promise<any> {
    switch (task.type) {
      case 'vrf':
        return this.testVRF(endpoint, task.payload);
      case 'dns_resolve':
        return this.testDNSResolution(endpoint, task.payload);
      case 'multi_chain':
        return this.testMultiChain(endpoint, task.payload);
      case 'prn_audit':
        return this.testPRNAudit(endpoint, task.payload);
      default:
        throw new Error(`Unknown task type: ${task.type}`);
    }
  }

  private async testVRF(endpoint: string, payload: any): Promise<any> {
    const response = await fetch(`${endpoint}/vrf/generate`, {
      method: 'POST',
      body: JSON.stringify(payload),
      headers: { 'Content-Type': 'application/json' }
    });
    return response.json();
  }

  private async testDNSResolution(endpoint: string, payload: any): Promise<any> {
    const response = await fetch(`${endpoint}/dns/query`, {
      method: 'POST',
      body: JSON.stringify(payload)
    });
    return response.json();
  }

  private async testMultiChain(endpoint: string, payload: any): Promise<any> {
    const response = await fetch(`${endpoint}/resolve`, {
      method: 'POST',
      body: JSON.stringify(payload)
    });
    return response.json();
  }

  private async testPRNAudit(endpoint: string, payload: any): Promise<any> {
    const response = await fetch(`${endpoint}/prn/audit`, {
      method: 'POST',
      body: JSON.stringify(payload)
    });
    return response.json();
  }

  generateReport(): {
    summary: any;
    details: TestResult[];
    recommendations: string[];
  } {
    const totalTasks = this.results.length;
    const successTasks = this.results.filter(r => r.success).length;
    const avgLatency = this.results.reduce((a, b) => a + b.latency, 0) / totalTasks;
    
    return {
      summary: {
        totalTasks,
        successRate: (successTasks / totalTasks * 100).toFixed(2) + '%',
        averageLatency: avgLatency.toFixed(2) + 'ms',
        globalThroughput: this.results.reduce((a, b) => a + b.throughput, 0)
      },
      details: this.results,
      recommendations: this.generateRecommendations()
    };
  }

  private generateRecommendations(): string[] {
    const recs: string[] = [];
    const highLatency = this.results.filter(r => r.latency > 200);
    if (highLatency.length > 0) {
      recs.push(`⚠️ Nodes ${highLatency.map(r => r.nodeId).join(', ')} show high latency. Consider optimizing network configuration.`);
    }
    if (this.results.some(r => r.errors > 0)) {
      recs.push('⚠️ Some requests failed. Please check PRN node health status.');
    }
    if (this.results.every(r => r.latency < 50)) {
      recs.push('✅ All nodes latency < 50ms. System status is excellent.');
    }
    return recs;
  }
}
```

### 3.2 Load Generator (`testnet/load-generator/src/vrf-test.ts`)

```typescript
// Author: J. Tian (uw2icg-core)

interface VRFTestConfig {
  concurrentConnections: number;
  totalRequests: number;
  rampUpTime: number;        // Seconds
  payloadSize: number;       // Bytes
}

export class VRFLoadGenerator {
  private results: Array<{ success: boolean; latency: number; error?: string }> = [];

  async runTest(targetUrl: string, config: VRFTestConfig): Promise<void> {
    console.log(`[VRF Test] Starting load test on ${targetUrl}`);
    console.log(`  Concurrent: ${config.concurrentConnections}`);
    console.log(`  Total Requests: ${config.totalRequests}`);
    console.log(`  Ramp Up: ${config.rampUpTime}s`);

    const startTime = Date.now();
    const promises = [];

    for (let i = 0; i < config.totalRequests; i++) {
      const promise = this.sendSingleRequest(targetUrl, i, config.payloadSize);
      promises.push(promise);

      if (i % config.concurrentConnections === 0) {
        await Promise.all(promises.splice(0, config.concurrentConnections));
      }
    }

    await Promise.all(promises);

    const totalTime = (Date.now() - startTime) / 1000;
    this.printReport(totalTime);
  }

  private async sendSingleRequest(
    targetUrl: string,
    index: number,
    payloadSize: number
  ): Promise<void> {
    const start = performance.now();
    try {
      const payload = {
        index,
        seed: crypto.randomUUID(),
        data: 'x'.repeat(payloadSize)
      };

      const response = await fetch(`${targetUrl}/vrf/generate`, {
        method: 'POST',
        body: JSON.stringify(payload),
        headers: { 'Content-Type': 'application/json' }
      });

      const end = performance.now();
      this.results.push({
        success: response.ok,
        latency: end - start
      });
    } catch (err) {
      const end = performance.now();
      this.results.push({
        success: false,
        latency: end - start,
        error: String(err)
      });
    }
  }

  private printReport(totalTime: number): void {
    const total = this.results.length;
    const success = this.results.filter(r => r.success).length;
    const latencies = this.results.map(r => r.latency).sort((a, b) => a - b);

    console.log('\n=== VRF Load Test Report ===');
    console.log(`Total Requests: ${total}`);
    console.log(`Success Rate: ${(success / total * 100).toFixed(2)}%`);
    console.log(`Total Time: ${totalTime.toFixed(2)}s`);
    console.log(`Throughput: ${(total / totalTime).toFixed(2)} req/s`);
    console.log(`Avg Latency: ${latencies.reduce((a, b) => a + b, 0) / total}ms`);
    console.log(`P95 Latency: ${latencies[Math.floor(total * 0.95)]}ms`);
    console.log(`P99 Latency: ${latencies[Math.floor(total * 0.99)]}ms`);
  }
}
```

