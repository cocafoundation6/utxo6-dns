pragma solidity ^0.8.19;

import "@openzeppelin/contracts/access/AccessControl.sol";
import "@openzeppelin/contracts/security/Pausable.sol";
import "@openzeppelin/contracts/security/ReentrancyGuard.sol";

contract HKCoCaDEX is AccessControl, Pausable, ReentrancyGuard {
    bytes32 public constant LICENSED_ROLE = keccak256("LICENSED_ROLE");
    bytes32 public constant REGULATOR_ROLE = keccak256("REGULATOR_ROLE");

    mapping(address => bool) public isLicensed;
    mapping(address => string) public licenseNumber;
    mapping(address => RWAToken) public rwaTokens;

    struct RWAToken {
        string name;
        string symbol;
        address issuer;
        uint256 totalSupply;
        uint256 reserveAmount;
        bool isActive;
        uint256 createdAt;
    }

    struct Conversion {
        address user;
        address token;
        uint256 amount;
        uint256 hkdAmount;
        uint256 timestamp;
        bool settled; // reserved for future settlement tracking
        bytes32 vleiHash;
    }

    event TokenRegistered(address indexed token, string name, string symbol, address issuer);
    event ConversionExecuted(address indexed user, address indexed token, uint256 amount, uint256 hkdAmount);
    event ConversionSettled(bytes32 indexed conversionId);
    event LicenseGranted(address indexed account, string licenseNumber);
    event LicenseRevoked(address indexed account);

    constructor() {
        _setupRole(DEFAULT_ADMIN_ROLE, msg.sender);
        _setupRole(REGULATOR_ROLE, msg.sender);
        _setupRole(LICENSED_ROLE, msg.sender);
    }

    function grantLicense(address account, string memory license) external onlyRole(REGULATOR_ROLE) {
        isLicensed[account] = true;
        licenseNumber[account] = license;
        _grantRole(LICENSED_ROLE, account);
        emit LicenseGranted(account, license);
    }

    function revokeLicense(address account) external onlyRole(REGULATOR_ROLE) {
        isLicensed[account] = false;
        delete licenseNumber[account];
        _revokeRole(LICENSED_ROLE, account);
        emit LicenseRevoked(account);
    }

    function registerRWAToken(
        address tokenAddress,
        string memory name,
        string memory symbol,
        uint256 totalSupply,
        uint256 reserveHKD
    ) external onlyRole(LICENSED_ROLE) {
        require(isLicensed[msg.sender], "Not licensed");
        require(!rwaTokens[tokenAddress].isActive, "Token already registered");
        rwaTokens[tokenAddress] = RWAToken({
            name: name,
            symbol: symbol,
            issuer: msg.sender,
            totalSupply: totalSupply,
            reserveAmount: reserveHKD,
            isActive: true,
            createdAt: block.timestamp
        });
        emit TokenRegistered(tokenAddress, name, symbol, msg.sender);
    }

    function convertHKDtoRWA(
        address tokenAddress,
        uint256 hkdAmount,
        bytes32 vleiHash
    ) external onlyRole(LICENSED_ROLE) whenNotPaused nonReentrant returns (bytes32) {
        require(isLicensed[msg.sender], "Not licensed");
        require(rwaTokens[tokenAddress].isActive, "Token not active");
        uint256 tokenAmount = (hkdAmount * rwaTokens[tokenAddress].totalSupply) / rwaTokens[tokenAddress].reserveAmount;
        bytes32 conversionId = keccak256(abi.encodePacked(msg.sender, tokenAddress, hkdAmount, block.timestamp));
        emit ConversionExecuted(msg.sender, tokenAddress, tokenAmount, hkdAmount);
        return conversionId;
    }

    function settleConversion(bytes32 conversionId) external onlyRole(REGULATOR_ROLE) {
        emit ConversionSettled(conversionId);
    }

    function emergencyPause() external onlyRole(REGULATOR_ROLE) {
        _pause();
    }

    function emergencyUnpause() external onlyRole(REGULATOR_ROLE) {
        _unpause();
    }
}
