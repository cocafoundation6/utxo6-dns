export class VLEIVerifier {
  private gleifEndpoint = 'https://api.gleif.org/v1/vlei/status';

  async verify(vleiDID: string): Promise<VLEIStatus> {
    if (!vleiDID.startsWith('did:vlei:')) {
      throw new Error('Invalid vLEI DID format');
    }
    const status = await this.queryGLEIF(vleiDID);
    return {
      valid: status.status === 'ACTIVE',
      status: status.status,
      legalName: status.legalName,
      legalAddress: status.legalAddress,
      jurisdiction: status.jurisdiction,
      lei: status.lei,
      lastUpdated: new Date()
    };
  }

  private async queryGLEIF(vleiDID: string): Promise<any> {
    // Mock response -- replace with actual GLEIF API call
    return {
      status: 'ACTIVE',
      legalName: `Legal Entity ${vleiDID.slice(-8)}`,
      legalAddress: '123 Main St, Hong Kong',
      jurisdiction: 'HK',
      lei: `LEI${vleiDID.slice(-18)}`
    };
  }

  async verifyCredential(credential: VLEICredential): Promise<boolean> {
    try {
      const now = new Date();
      if (credential.validFrom > now || credential.validUntil < now) return false;
      const status = await this.verify(credential.subject);
      if (!status.valid) return false;
      for (const auth of credential.authorization) {
        if (!auth.role || !auth.authority) return false;
      }
      return true;
    } catch {
      return false;
    }
  }

  async batchVerify(vleiDIDs: string[]): Promise<Map<string, VLEIStatus>> {
    const results = new Map<string, VLEIStatus>();
    for (const did of vleiDIDs) {
      try {
        const status = await this.verify(did);
        results.set(did, status);
      } catch {
        results.set(did, {
          valid: false,
          status: 'REVOKED',
          legalName: '',
          legalAddress: '',
          jurisdiction: '',
          lei: '',
          lastUpdated: new Date()
        });
      }
    }
    return results;
  }
}
