```typescript
// packages/core/iso20022/extensions.ts
// Author: J. Tian (uw2icg-core)

export interface ISO20022Extension {
  ultimateDebtor: {
    name: string;
    id: { scheme: 'UTXO' | 'LEI' | 'BIC'; value: string };
    postalAddress?: { country: string; city: string; postalCode: string; street: string };
  };
  ultimateCreditor: {
    name: string;
    id: { scheme: 'UTXO' | 'LEI' | 'BIC'; value: string };
    postalAddress?: { country: string; city: string; postalCode: string; street: string };
  };
  currency: {
    code: 'EUR' | 'CNY' | 'CNH' | 'USD' | 'HKD';
    utxoWalletId?: string;
  };
  purpose: 'GOODS_SERVICES' | 'TOURISM' | 'REMITTANCE' | 'INVESTMENT';
}

export interface ISO20022PaymentInstruction {
  messageId: string;
  creationDateTime: Date;
  numberOfTransactions: number;
  settlementInformation: {
    settlementMethod: 'INDA' | 'INGA' | 'COVE';
    clearingChannel: 'RTGS' | 'ACH' | 'CBDC';
    currency: string;
  };
  paymentInfo: Array<{
    paymentId: string;
    paymentMethod: 'TRF' | 'CHK' | 'DD';
    amount: { instructedAmount: number; currency: string };
    exchangeRate?: number;
    chargeBearer: 'DEBT' | 'CRED' | 'SHAR' | 'SLEV';
    ultimateDebtor: ISO20022Extension['ultimateDebtor'];
    ultimateCreditor: ISO20022Extension['ultimateCreditor'];
    purpose: ISO20022Extension['purpose'];
    regulatoryReporting: Array<{ regulatoryAuthority: string; reportingCode: string; amount: number }>;
  }>;
}

export class ISO20022PaymentBuilder {
  private message: ISO20022PaymentInstruction;

  constructor() {
    this.message = {
      messageId: this.generateMessageId(),
      creationDateTime: new Date(),
      numberOfTransactions: 1,
      settlementInformation: {
        settlementMethod: 'INDA',
        clearingChannel: 'CBDC',
        currency: 'CNY'
      },
      paymentInfo: []
    };
  }

  private generateMessageId(): string {
    return `MSG${Date.now()}${Math.floor(Math.random() * 10000)}`;
  }

  setCurrency(code: 'EUR' | 'CNY' | 'CNH' | 'USD' | 'HKD', utxoWalletId?: string): this {
    this.message.settlementInformation.currency = code;
    return this;
  }

  addPaymentInfo(info: {
    amount: number;
    currency: string;
    debtor: ISO20022Extension['ultimateDebtor'];
    creditor: ISO20022Extension['ultimateCreditor'];
    purpose: ISO20022Extension['purpose'];
  }): this {
    this.message.paymentInfo.push({
      paymentId: `PAY${Date.now()}${Math.floor(Math.random() * 1000)}`,
      paymentMethod: 'TRF',
      amount: { instructedAmount: info.amount, currency: info.currency },
      chargeBearer: 'DEBT',
      ultimateDebtor: info.debtor,
      ultimateCreditor: info.creditor,
      purpose: info.purpose,
      regulatoryReporting: this.buildRegulatoryReporting(info)
    });
    return this;
  }

  private buildRegulatoryReporting(info: { amount: number; currency: string }):
    ISO20022PaymentInstruction['paymentInfo'][0]['regulatoryReporting'] {
    if (info.currency !== 'CNY') {
      return [{ regulatoryAuthority: 'SAFE', reportingCode: 'CROSS_BORDER', amount: info.amount }];
    }
    return [];
  }

  build(): ISO20022PaymentInstruction {
    return this.message;
  }

  toXML(): string {
    return this.generateXMLFromMessage(this.message);
  }

  private generateXMLFromMessage(msg: ISO20022PaymentInstruction): string {
    return `<?xml version="1.0" encoding="UTF-8"?>
<Document xmlns="urn:iso:std:iso:20022:tech:xsd:pacs.008.001.12">
  <FIToFICstmrCdtTrf>
    <GrpHdr>
      <MsgId>${msg.messageId}</MsgId>
      <CreDtTm>${msg.creationDateTime.toISOString()}</CreDtTm>
      <NbOfTxs>${msg.numberOfTransactions}</NbOfTxs>
      <SttlmInf>
        <SttlmMtd>${msg.settlementInformation.settlementMethod}</SttlmMtd>
        <ClrChan>${msg.settlementInformation.clearingChannel}</ClrChan>
      </SttlmInf>
    </GrpHdr>
    ${msg.paymentInfo.map(p => this.generatePaymentInfoXML(p)).join('')}
  </FIToFICstmrCdtTrf>
</Document>`;
  }

  private generatePaymentInfoXML(p: ISO20022PaymentInstruction['paymentInfo'][0]): string {
    return `
  <CdtTrfTxInf>
    <PmtId>
      <InstrId>${p.paymentId}</InstrId>
      <EndToEndId>${p.paymentId}</EndToEndId>
    </PmtId>
    <PmtTpInf>
      <CtgyPurp>
        <Cd>${p.purpose === 'TOURISM' ? 'TOUR' : p.purpose === 'GOODS_SERVICES' ? 'GDDS' : 'REMT'}</Cd>
      </CtgyPurp>
    </PmtTpInf>
    <Amt>
      <InstdAmt Ccy="${p.amount.currency}">${p.amount.instructedAmount.toFixed(2)}</InstdAmt>
    </Amt>
    <UltmtDbtr>
      <Nm>${p.ultimateDebtor.name}</Nm>
      <Id>
        <OrgId>
          <Othr>
            <Id>${p.ultimateDebtor.id.value}</Id>
            <SchmeNm><Cd>${p.ultimateDebtor.id.scheme}</Cd></SchmeNm>
          </Othr>
        </OrgId>
      </Id>
    </UltmtDbtr>
    <UltmtCdtr>
      <Nm>${p.ultimateCreditor.name}</Nm>
      <Id>
        <OrgId>
          <Othr>
            <Id>${p.ultimateCreditor.id.value}</Id>
            <SchmeNm><Cd>${p.ultimateCreditor.id.scheme}</Cd></SchmeNm>
          </Othr>
        </OrgId>
      </Id>
    </UltmtCdtr>
  </CdtTrfTxInf>`;
  }
}
