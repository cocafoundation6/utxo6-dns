import { RegionComplianceRouter } from '../../packages/core/compliance-router/RegionRouter';

describe('xHKDAP Integration Tests', () => {
  let gateway: HKDAPGateway;
  let compliance: HKDAPComplianceRouter;
  let adapter: ECNYHKDAPAdapter;
  let router: RegionComplianceRouter;

  beforeEach(() => {
    gateway = new HKDAPGateway({ contractAddress: '0x...', rpcUrl: 'https://...' });
    compliance = new HKDAPComplianceRouter();
    router = new RegionComplianceRouter();
    adapter = new ECNYHKDAPAdapter(gateway, router);
  });

  test('HKDAP payment creation', async () => {
    const result = await gateway.createPayment({
      amount: 1000,
      recipientAddress: '0x1234567890123456789012345678901234567890',
      purpose: 'P2P'
    });
    expect(result.transactionId).toMatch(/^HKDAP_/);
    expect(result.status).toBe('PENDING');
  });

  test('HKDAP compliance check -- exceeds limit', async () => {
    const result = await compliance.checkCompliance({
      from: '0x...',
      to: '0x...',
      amount: 2000000,
      purpose: 'P2P'
    });
    expect(result.approved).toBe(false);
    expect(result.reason).toContain('Exceeds single transaction limit');
  });

  test('e-CNY to HKDAP conversion -- HK licensed only', async () => {
    await router.registerUser({
      userId: 'hk_entity',
      region: 'HK_LICENSED',
      kycLevel: 3,
      yearlyOutboundLimit: 5000000,
      yearlyUsed: 0
    });
    const result = await adapter.convertECNYtoHKDAP(
      'hk_entity',
      10000,
      '0xRecipientAddress'
    );
    expect(result.hkdapAmount).toBeGreaterThan(0);
    expect(result.transactionId).toMatch(/^ECNY2HKDAP_/);
  });

  test('e-CNY to HKDAP conversion -- mainland user rejected', async () => {
    await router.registerUser({
      userId: 'mainland_user',
      region: 'MAINLAND',
      kycLevel: 2,
      yearlyOutboundLimit: 50000,
      yearlyUsed: 0
    });
    await expect(adapter.convertECNYtoHKDAP(
      'mainland_user',
      10000,
      '0xRecipientAddress'
    )).rejects.toThrow('Only HK licensed entities');
  });
});
