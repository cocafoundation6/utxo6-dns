// packages/core/journal/JournalService.ts
// Author: J. Tian (uw2icg-core)

export interface JournalEntry {
  id: string;
  userId: string;
  timestamp: Date;
  amount: number;
  currency: 'CNY' | 'EUR' | 'CNH' | 'USD' | 'HKD';
  type: 'DEBIT' | 'CREDIT';
  reference: string;
  metadata: Record<string, any>;
}

export interface WalletBalance {
  userId: string;
  balances: { CNY: number; EUR: number; CNH: number; USD: number; HKD: number };
  lastUpdated: Date;
}

export class JournalService {
  private entries: JournalEntry[] = [];
  private balances: Map<string, WalletBalance> = new Map();

  async recordEntry(entry: Omit<JournalEntry, 'id' | 'timestamp'>): Promise<JournalEntry> {
    const fullEntry: JournalEntry = {
      id: this.generateId(),
      timestamp: new Date(),
      ...entry
    };
    this.entries.push(fullEntry);
    await this.updateBalance(entry.userId, entry.currency, entry.amount, entry.type);
    return fullEntry;
  }

  private generateId(): string {
    return `JRNL${Date.now()}${Math.floor(Math.random() * 10000)}`;
  }

  private async updateBalance(userId: string, currency: string, amount: number, type: 'DEBIT' | 'CREDIT'): Promise<void> {
    let balance = this.balances.get(userId);
    if (!balance) {
      balance = {
        userId,
        balances: { CNY: 0, EUR: 0, CNH: 0, USD: 0, HKD: 0 },
        lastUpdated: new Date()
      };
    }
    const key = currency as keyof typeof balance.balances;
    if (type === 'CREDIT') {
      balance.balances[key] += amount;
    } else {
      balance.balances[key] -= amount;
    }
    balance.lastUpdated = new Date();
    this.balances.set(userId, balance);
  }

  async getBalance(userId: string): Promise<WalletBalance | null> {
    return this.balances.get(userId) || null;
  }

  async getEntries(userId: string, startDate?: Date, endDate?: Date): Promise<JournalEntry[]> {
    let result = this.entries.filter(e => e.userId === userId);
    if (startDate) result = result.filter(e => e.timestamp >= startDate);
    if (endDate) result = result.filter(e => e.timestamp <= endDate);
    return result.sort((a, b) => b.timestamp.getTime() - a.timestamp.getTime());
  }

  async generateAuditSummary(userId: string, period: { start: Date; end: Date }) {
    const entries = await this.getEntries(userId, period.start, period.end);
    const totalDebit: Record<string, number> = {};
    const totalCredit: Record<string, number> = {};
    for (const entry of entries) {
      if (entry.type === 'DEBIT') {
        totalDebit[entry.currency] = (totalDebit[entry.currency] || 0) + entry.amount;
      } else {
        totalCredit[entry.currency] = (totalCredit[entry.currency] || 0) + entry.amount;
      }
    }
    const netPosition: Record<string, number> = {};
    const allCurrencies = new Set([...Object.keys(totalDebit), ...Object.keys(totalCredit)]);
    for (const currency of allCurrencies) {
      netPosition[currency] = (totalCredit[currency] || 0) - (totalDebit[currency] || 0);
    }
    return { totalDebit, totalCredit, netPosition, transactionCount: entries.length };
  }
}
